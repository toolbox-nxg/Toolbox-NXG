{
    "name": "moderator-toolbox-nxg-for-reddit",
    "description": "A set of tools to be used by moderators on reddit in order to make their jobs easier.",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "del-cli build && rollup -c rollup.config.js",
        "build:chrome": "cross-env BUILD_TARGET=chrome npm run build",
        "build:firefox": "cross-env BUILD_TARGET=firefox npm run build",
        "build:watch": "rollup -c rollup.config.js --watch",
        "build:watch:chrome": "cross-env BUILD_TARGET=chrome npm run build:watch",
        "build:watch:firefox": "cross-env BUILD_TARGET=firefox npm run build:watch",
        "lint": "eslint . && npm run lint:guard",
        "lint:fix": "eslint . --fix",
        "lint:params": "node scripts/check-param-order.mjs",
        "lint:guard": "node scripts/check-moderation-imports.mjs",
        "lint:css": "stylelint \"extension/**/*.css\"",
        "lint:css:fix": "stylelint \"extension/**/*.css\" --fix",
        "fmt": "dprint check",
        "fmt:fix": "dprint fmt",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "docs:api": "typedoc",
        "release": "node scripts/release.mjs",
        "postinstall": "patch-package"
    },
    "homepage": "http://www.reddit.com/r/toolbox_nxg",
    "repository": {
        "type": "git",
        "url": "https://github.com/toolbox-nxg/toolbox-nxg.git"
    },
    "engines": {
        "node": ">=24"
    },
    "license": "Apache-2.0",
    "dependencies": {
        "@babel/runtime": "^8.0.0",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/lint": "^6.9.7",
        "@codemirror/search": "^6.7.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@reduxjs/toolkit": "^2.12.0",
        "@uiw/codemirror-themes-all": "^4.25.10",
        "async-mutex": "^0.5.0",
        "codemirror": "^6.0.2",
        "dompurify": "^3.4.11",
        "framer-motion": "^12.40.0",
        "iter-ops": "^3.5.0",
        "pako": "^2.1.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-redux": "^9.3.0",
        "snuownd": "github:gamefreak/snuownd#533e8dcb67fe8e4ddc83fb8317ed0d10c25b6fcb",
        "tinycolor2": "^1.6.0",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@inquirer/input": "^5.1.2",
        "@inquirer/select": "^5.2.1",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-replace": "^6.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@tsconfig/recommended": "^1.0.13",
        "@types/minimatch": "^6.0.0",
        "@types/pako": "^2.0.4",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@types/webextension-polyfill": "^0.12.5",
        "cross-env": "^10.1.0",
        "del-cli": "^7.0.0",
        "dprint": "^0.54.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0",
        "happy-dom": "^20.10.6",
        "jsdom": "^29.1.1",
        "patch-package": "^8.0.1",
        "rollup": "^4.62.2",
        "rollup-plugin-copy": "^3.5.0",
        "rollup-plugin-postcss": "^4.0.2",
        "stylelint": "^17.13.0",
        "stylelint-config-standard": "^40.0.0",
        "typedoc": "^0.28.0",
        "typedoc-plugin-markdown": "^4.6.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vitest": "^4.1.8"
    },
    "optionalDependencies": {
        "@rolldown/binding-linux-x64-gnu": "^1.1.2"
    }
}
